generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id            String       @id @default(cuid())
  clerkUserId   String?      @unique @map("clerk_user_id")
  cim           String?      @unique
  fullName      String       @map("full_name")
  email         String       @unique
  phone         String?
  status        MemberStatus @default(ativo)
  joinedAt      DateTime?    @map("joined_at")
  notesInternal String?      @map("notes_internal")
  creditBalance Decimal      @default(0) @map("credit_balance") @db.Decimal(10, 2)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  auditLogs     AuditLog[]
  charges       Charge[]
  payments      Payment[]

  @@map("members")
}

model ChargeType {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  defaultAmount        Decimal?              @map("default_amount") @db.Decimal(10, 2)
  isRecurring          Boolean               @default(false) @map("is_recurring")
  active               Boolean               @default(true)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  charges              Charge[]
  recurringChargeRules RecurringChargeRule[]

  @@map("charge_types")
}

model Charge {
  id                 String              @id @default(cuid())
  memberId           String              @map("member_id")
  chargeTypeId       String              @map("charge_type_id")
  competenceDate     DateTime            @map("competence_date") @db.Date
  dueDate            DateTime            @map("due_date") @db.Date
  description        String?
  amount             Decimal             @map("amount") @db.Decimal(10, 2)
  status             ChargeStatus        @default(pendente)
  createdBy          String?             @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  chargeType         ChargeType          @relation(fields: [chargeTypeId], references: [id])
  member             Member              @relation(fields: [memberId], references: [id])
  paymentAllocations PaymentAllocation[]

  @@map("charges")
}

model Payment {
  id                 String              @id @default(cuid())
  memberId           String              @map("member_id")
  paymentDate        DateTime            @map("payment_date") @db.Date
  amount             Decimal             @map("amount") @db.Decimal(10, 2)
  paymentMethod      String?             @map("payment_method")
  notes              String?
  createdBy          String?             @map("created_by")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  attachments        Attachment[]
  cashTransactions   CashTransaction[]
  paymentAllocations PaymentAllocation[]
  member             Member              @relation(fields: [memberId], references: [id])

  @@map("payments")
}

model PaymentAllocation {
  id              String  @id @default(cuid())
  paymentId       String  @map("payment_id")
  chargeId        String  @map("charge_id")
  allocatedAmount Decimal @map("allocated_amount") @db.Decimal(10, 2)
  charge          Charge  @relation(fields: [chargeId], references: [id])
  payment         Payment @relation(fields: [paymentId], references: [id])

  @@map("payment_allocations")
}

model Attachment {
  id         String   @id @default(cuid())
  ownerType  String   @map("owner_type")
  ownerId    String   @map("owner_id")
  fileUrl    String   @map("file_url")
  fileName   String   @map("file_name")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")
  payment    Payment  @relation(fields: [ownerId], references: [id])

  @@map("attachments")
}

model RecurringChargeRule {
  id           String     @id @default(cuid())
  chargeTypeId String     @map("charge_type_id")
  frequency    String     @default("monthly")
  amount       Decimal    @map("amount") @db.Decimal(10, 2)
  active       Boolean    @default(true)
  paramsJson   Json?      @map("params_json")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  chargeType   ChargeType @relation(fields: [chargeTypeId], references: [id])

  @@map("recurring_charge_rules")
}

model CashTransaction {
  id               String              @id @default(cuid())
  type             CashTransactionType
  category         String
  description      String?
  amount           Decimal             @map("amount") @db.Decimal(10, 2)
  transactionDate  DateTime            @map("transaction_date") @db.Date
  relatedMemberId  String?             @map("related_member_id")
  relatedPaymentId String?             @map("related_payment_id")
  createdBy        String?             @map("created_by")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  relatedPayment   Payment?            @relation(fields: [relatedPaymentId], references: [id])

  @@map("cash_transactions")
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String?  @map("org_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  oldDataJson Json?    @map("old_data_json")
  newDataJson Json?    @map("new_data_json")
  createdAt   DateTime @default(now()) @map("created_at")
  actorMember Member?  @relation(fields: [actorUserId], references: [clerkUserId])

  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
  @@index([orgId, actorUserId, createdAt])

  @@map("audit_logs")
}

model PeriodClosing {
  id              String   @id @default(cuid())
  competenceMonth Int      @map("competence_month")
  competenceYear  Int      @map("competence_year")
  closedBy        String?  @map("closed_by")
  closedAt        DateTime @default(now()) @map("closed_at")
  totalCharged    Decimal  @map("total_charged") @db.Decimal(10, 2)
  totalReceived   Decimal  @map("total_received") @db.Decimal(10, 2)
  balance         Decimal  @map("balance") @db.Decimal(10, 2)
  notes           String?

  @@unique([competenceMonth, competenceYear])
  @@map("period_closings")
}

enum MemberStatus {
  ativo
  inativo
  licenciado
  remido
}

enum ChargeStatus {
  pendente
  parcialmente_paga
  paga
  cancelada
  estornada
}

enum CashTransactionType {
  entrada
  saida
}
